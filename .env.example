# Maya Scripts Manager の設定サンプル
# このファイルを ".env" にコピーし、環境に合わせてパスを書き換えてください。
# .env は mayascriptsmanager.py と同じ場所に置きます。

# JSON（スクリプトリスト）の書き出し／読み込みダイアログで最初に開くパス
# 例: 共有ドライブ上の repo フォルダなど（各自の環境の任意のパスを指定）
# Starting folder for the export/import JSON dialogs.
SCRIPT_REPO_PATH=X:\path\to\MayaScriptsManager\repo

# UI 言語 / UI language: "ja" or "en"
# 未指定の場合は Maya の UI 言語から自動判定（日本語以外は英語）。
# If omitted, auto-detected from Maya's UI language (English for non-Japanese).
LANG=en
